---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
---

<BaseLayout
  lang="en"
  title="Legal Notice | Lattise"
  description="Legal notice and regulatory information."
>
  <div id="top">
    <Header homePath={`${import.meta.env.BASE_URL}`} />

    <main class="legal-page">
      <section class="legal-hero">
        <div class="container legal-hero-card">
          <span class="eyebrow">Legal</span>
          <h1>Legal Notice</h1>
          <p>
            Company details, required disclosures, and regulatory notices in the
            Lattise visual language.
          </p>
        </div>
      </section>

      <section class="legal-sections">
        <div class="container legal-grid">
          <article class="legal-card">
            <span class="card-label">Company</span>
            <h2>Required Information</h2>
            <div class="legal-copy">
              <p>Lattise Seating Solutions LLC</p>
              <p>1250 Market Street, Suite 400</p>
              <p>San Francisco, CA 94103</p>
              <p>USA</p>
              <p>Phone: +1 (415) 555-7832</p>
              <p>Email: lattise@rights.com</p>
              <p>Managing Director: Christoph Nerger</p>
              <p>Registered Office: San Francisco, California, USA</p>
              <p>Legal Form: Limited Liability Company (LLC)</p>
              <p>Register Authority: California Secretary of State</p>
              <p>File Number: LLC-2026-8745632</p>
              <p>Employer Identification Number (EIN): 92-7654321</p>
            </div>
          </article>

          <article class="legal-card">
            <span class="card-label">Contact</span>
            <h2>Imprint Contact</h2>
            <div class="legal-copy">
              <p>For legal inquiries regarding this website, please contact:</p>
              <p>Lattise Seating Solutions LLC</p>
              <p>Phone: +1 (415) 555-7832</p>
              <p>Email: lattise@rights.com</p>
            </div>
          </article>

          <article class="legal-card legal-card-wide">
            <span class="card-label">Notices</span>
            <h2>Legal Information</h2>
            <div class="legal-copy">
              <h3>Disclaimer</h3>
              <p>
                The information available on these pages makes no claim to
                accuracy or completeness. Use is at your own risk. We expressly
                note that we are not responsible for third-party offers on the
                World Wide Web, including so-called deep links. To the best of
                our knowledge, references to third-party offers do not contain
                any criminal or otherwise prohibited content. No liability is
                assumed for such content.
              </p>

              <h3>Dispute Resolution</h3>
              <p>
                Lattise Seating Solutions LLC is not willing or obligated to
                participate in dispute resolution proceedings before a consumer
                arbitration board unless required by applicable law.
              </p>

              <h3>Copyright Notice</h3>
              <p>
                The content and structure of this website
                are protected by copyright. Any reproduction of information or
                data, especially the use of texts, parts of texts, images, or
                other content, requires the prior consent of the provider or
                rights holder.
              </p>

              <h3>Intellectual Property Infringement</h3>
              <p>
                If you suspect that one of your intellectual property rights is
                being infringed by this website, please notify us immediately by
                email so that prompt remedial action can be taken.
              </p>

              <h3>Investor Relations</h3>
              <p>
                For investor relations or corporate information requests, please
                contact
                <a href="mailto:lattise@rights.com">lattise@rights.com</a>.
              </p>

              <p>April 2026</p>
            </div>
          </article>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>

<style>
  .legal-page {
    padding-bottom: 4rem;
  }

  .legal-hero {
    padding: 4rem 0 1.5rem;
  }

  .legal-hero-card,
  .legal-card {
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0.58));
    box-shadow: var(--shadow-soft);
  }

  .legal-hero-card {
    padding: clamp(2rem, 4vw, 3.5rem);
  }

  .legal-hero-card h1 {
    margin-bottom: 1rem;
    font-size: clamp(3rem, 7vw, 5rem);
    line-height: 0.94;
  }

  .legal-hero-card p {
    max-width: 42rem;
    margin-bottom: 0;
    font-size: 1.05rem;
  }

  .legal-sections {
    padding: 1.5rem 0 2rem;
  }

  .legal-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
    align-items: start;
  }

  .legal-card {
    padding: clamp(1.75rem, 3vw, 2.4rem);
  }

  .legal-card-wide {
    grid-column: 1 / -1;
  }

  .card-label {
    display: inline-block;
    margin-bottom: 1rem;
    color: var(--accent);
    font-size: 0.78rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .eyebrow {
    display: inline-block;
    margin-bottom: 1.25rem;
    color: var(--accent);
    font-size: 0.78rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .legal-card h2 {
    margin-bottom: 1rem;
    font-size: clamp(1.9rem, 4vw, 2.8rem);
    line-height: 1;
  }

  .legal-copy {
    display: grid;
    gap: 0.75rem;
  }

  .legal-copy h3 {
    margin: 1rem 0 0;
    font-size: 1.2rem;
  }

  .legal-copy p {
    margin-bottom: 0;
  }

  .legal-copy a {
    text-decoration: underline;
    text-underline-offset: 0.14em;
  }

  @media (max-width: 900px) {
    .legal-grid {
      grid-template-columns: 1fr;
    }

    .legal-card-wide {
      grid-column: auto;
    }
  }

  @media (max-width: 640px) {
    .legal-hero {
      padding-top: 3rem;
    }

    .legal-card,
    .legal-hero-card {
      padding: 1.5rem;
    }
  }
</style>
