---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
---

<BaseLayout
  title="Fictional Company"
  description="Responsive Astro starter website for a fictional company."
>
  <Header />

  <main id="top">
    <section class="hero">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">Responsive Astro Website Starter</p>
          <h1>Build the company story later. Keep the structure solid now.</h1>
          <p class="hero-text">
            This Astro starter gives you a flexible homepage layout for a fictional
            company with semantic sections and device-friendly behavior out of the box.
          </p>
          <div class="hero-actions">
            <a class="button primary" href="#services">Explore Sections</a>
            <a class="button secondary" href="#contact">Call to Action Area</a>
          </div>
        </div>

        <div class="hero-panel" aria-label="Company highlights">
          <article class="stat-card">
            <span class="stat-value">01</span>
            <p>Astro-based structure ready to rename and restyle.</p>
          </article>
          <article class="stat-card">
            <span class="stat-value">02</span>
            <p>Responsive behavior for phones, tablets, and laptops.</p>
          </article>
          <article class="stat-card">
            <span class="stat-value">03</span>
            <p>Reusable sections you can expand into a full company site.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section" id="about">
      <div class="container section-grid">
        <div>
          <p class="eyebrow">About</p>
          <h2>A placeholder company profile with room to grow.</h2>
        </div>
        <div>
          <p>
            Use this section for the company mission, background, or what makes the
            business different. The content is intentionally generic so you can swap
            in real copy later without changing the layout.
          </p>
        </div>
      </div>
    </section>

    <section class="section alt" id="services">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Services</p>
          <h2>Three reusable feature cards for core offerings.</h2>
        </div>

        <div class="card-grid">
          <article class="info-card">
            <h3>Service One</h3>
            <p>Replace this with a key product, capability, or business area.</p>
          </article>
          <article class="info-card">
            <h3>Service Two</h3>
            <p>Keep descriptions short and focused so the section stays scannable.</p>
          </article>
          <article class="info-card">
            <h3>Service Three</h3>
            <p>Add more cards later if needed without changing the responsive pattern.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section" id="process">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Process</p>
          <h2>A simple flow that explains how the company works.</h2>
        </div>

        <div class="timeline">
          <article class="timeline-item">
            <span>Step 1</span>
            <h3>Introduce the company</h3>
            <p>Summarize the problem you solve or the market you serve.</p>
          </article>
          <article class="timeline-item">
            <span>Step 2</span>
            <h3>Show the offer</h3>
            <p>Describe services, products, or engagement models in simple language.</p>
          </article>
          <article class="timeline-item">
            <span>Step 3</span>
            <h3>Invite action</h3>
            <p>Add a form, booking link, or contact method when the company is defined.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section accent" id="contact">
      <div class="container contact-panel">
        <div>
          <p class="eyebrow">Contact</p>
          <h2>Ready for a real CTA when the company details are finalized.</h2>
        </div>
        <a class="button primary light" href="mailto:hello@example.com">hello@example.com</a>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container footer-wrap">
      <p>Fictional Company starter site</p>
      <p>Built with Astro and prepared for Vercel deployment.</p>
    </div>
  </footer>
</BaseLayout>

<style>
  .hero,
  .section {
    padding: 5rem 0;
  }

  .hero-grid,
  .section-grid,
  .card-grid,
  .timeline,
  .contact-panel,
  .footer-wrap {
    display: grid;
    gap: 1.5rem;
  }

  .hero-grid {
    grid-template-columns: 1.25fr 1fr;
    align-items: center;
    min-height: calc(100svh - 5rem);
  }

  .eyebrow {
    margin-bottom: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--accent);
  }

  h1 {
    font-size: clamp(2.6rem, 7vw, 5rem);
    line-height: 0.97;
    max-width: 11ch;
    margin-bottom: 1.25rem;
  }

  h2 {
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.05;
    margin-bottom: 0;
  }

  h3 {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }

  .hero-text,
  .section p,
  .info-card p,
  .timeline-item p,
  .stat-card p,
  .site-footer p {
    color: var(--muted);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.25rem;
    padding: 0.85rem 1.25rem;
    border-radius: 999px;
    font-weight: 700;
    transition: transform 180ms ease, background-color 180ms ease;
  }

  .button:hover,
  .button:focus-visible {
    transform: translateY(-1px);
  }

  .button.primary {
    color: #fff;
    background: var(--text);
  }

  .button.primary.light {
    background: #fff;
    color: var(--text);
  }

  .button.secondary {
    background: var(--surface);
    border: 1px solid var(--line);
  }

  .hero-panel,
  .card-grid,
  .timeline {
    display: grid;
    gap: 1rem;
  }

  .hero-panel {
    padding: 1rem;
    border-radius: var(--radius-lg);
    background: rgba(255, 253, 248, 0.75);
    border: 1px solid rgba(21, 35, 31, 0.08);
    box-shadow: var(--shadow);
  }

  .stat-card,
  .info-card,
  .timeline-item {
    padding: 1.5rem;
    border-radius: var(--radius-md);
    background: var(--surface-strong);
    border: 1px solid var(--line);
  }

  .stat-value,
  .timeline-item span {
    display: inline-block;
    margin-bottom: 0.8rem;
    color: var(--accent);
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .section-grid {
    grid-template-columns: 1fr 1fr;
  }

  .section-heading {
    max-width: 42rem;
    margin-bottom: 2rem;
  }

  .card-grid,
  .timeline {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .alt {
    background: rgba(255, 255, 255, 0.42);
  }

  .accent {
    padding-top: 0;
  }

  .contact-panel {
    grid-template-columns: 1fr auto;
    align-items: center;
    padding: 2rem;
    border-radius: var(--radius-lg);
    background: linear-gradient(135deg, #0f766e, #165e56);
    color: #fff;
    box-shadow: var(--shadow);
  }

  .contact-panel .eyebrow,
  .contact-panel p {
    color: rgba(255, 255, 255, 0.78);
  }

  .site-footer {
    padding: 0 0 2rem;
  }

  .footer-wrap {
    grid-template-columns: 1fr auto;
    padding-top: 1rem;
    border-top: 1px solid rgba(21, 35, 31, 0.12);
  }

  @media (max-width: 900px) {
    .hero-grid,
    .section-grid,
    .card-grid,
    .timeline,
    .contact-panel,
    .footer-wrap {
      grid-template-columns: 1fr;
    }

    .hero {
      padding-top: 3rem;
    }

    .hero-grid {
      min-height: auto;
    }
  }

  @media (max-width: 720px) {
    .hero,
    .section {
      padding: 4rem 0;
    }

    h1 {
      max-width: 100%;
    }
  }

  @media (max-width: 480px) {
    :global(:root) {
      --container: min(1120px, calc(100% - 1.25rem));
    }

    .button {
      width: 100%;
    }

    .hero-actions {
      gap: 0.75rem;
    }

    .contact-panel {
      padding: 1.5rem;
    }
  }
</style>
