---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
---

<BaseLayout>
  <div id="top">
    <Header />

    <main>
      <section class="hero">
        <div class="container hero-grid">
          <div class="hero-copy">
            <span class="eyebrow">Lattis Seating Solutions</span>
            <h1>Quiet luxury, designed for the way people gather.</h1>
            <p>
              Lattis creates refined seating environments with sculpted comfort,
              understated detail, and a calm architectural presence.
            </p>

            <div class="hero-actions">
              <a class="button button-primary" href="#collection">Explore Collection</a>
              <a class="button button-secondary" href="#contact">Request Consultation</a>
            </div>
          </div>

          <div class="hero-card">
            <div class="hero-card-inner">
              <span class="card-label">Signature Approach</span>
              <h2>Tailored seating for elevated interiors.</h2>
              <p>
                From hospitality lounges to executive spaces, every piece is
                shaped around proportion, material depth, and long-lasting ease.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section class="section" id="collection">
        <div class="container">
          <div class="section-heading">
            <span class="eyebrow">Collection</span>
            <h2>Three expressions of elegant comfort.</h2>
          </div>

          <div class="collection-grid">
            <article class="panel">
              <span class="panel-index">01</span>
              <h3>Lounge</h3>
              <p>
                Deep silhouettes with soft contours for reception areas, suites,
                and intimate waiting spaces.
              </p>
            </article>

            <article class="panel">
              <span class="panel-index">02</span>
              <h3>Dining</h3>
              <p>
                Balanced support and graceful lines designed for long dinners,
                conversation, and understated sophistication.
              </p>
            </article>

            <article class="panel">
              <span class="panel-index">03</span>
              <h3>Executive</h3>
              <p>
                Structured forms with a quieter presence for boardrooms,
                private offices, and premium shared environments.
              </p>
            </article>
          </div>
        </div>
      </section>

      <section class="section section-split" id="craft">
        <div class="container split-grid">
          <div>
            <span class="eyebrow">Craft</span>
            <h2>Material restraint with a distinctive finish.</h2>
          </div>

          <div class="split-copy">
            <p>
              We combine clean geometry with tactile upholstery, fine stitching,
              and a warm tonal palette to create seating that feels quietly
              exceptional instead of overstated.
            </p>
            <p>
              Every decision is reduced to what matters most: comfort,
              proportion, and timeless atmosphere.
            </p>
          </div>
        </div>
      </section>

      <section class="section" id="process">
        <div class="container">
          <div class="section-heading">
            <span class="eyebrow">Process</span>
            <h2>A clear path from concept to placement.</h2>
          </div>

          <div class="process-grid">
            <article class="process-step">
              <strong>01</strong>
              <h3>Consult</h3>
              <p>We define atmosphere, dimensions, and functional priorities.</p>
            </article>

            <article class="process-step">
              <strong>02</strong>
              <h3>Curate</h3>
              <p>We align silhouettes, tones, and finishes with your interior vision.</p>
            </article>

            <article class="process-step">
              <strong>03</strong>
              <h3>Deliver</h3>
              <p>We complete the setting with seating that feels measured and lasting.</p>
            </article>
          </div>
        </div>
      </section>

      <section class="section" id="contact">
        <div class="container contact-card">
          <span class="eyebrow">Contact</span>
          <h2>Bring a calmer, more luxurious seating language into your space.</h2>
          <p>
            Begin with a conversation about your project, ambience, and seating needs.
          </p>
          <a class="button button-primary" href="mailto:studio@lattis.com">studio@lattis.com</a>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>

<style>
  main {
    padding-bottom: 4rem;
  }

  .hero {
    padding: 5.5rem 0 3rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
    gap: 1.5rem;
    align-items: stretch;
  }

  .hero-copy,
  .hero-card,
  .panel,
  .process-step,
  .contact-card {
    border: 1px solid var(--line);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0.58));
    box-shadow: var(--shadow-soft);
  }

  .hero-copy {
    padding: clamp(2rem, 4vw, 4rem);
    border-radius: var(--radius-xl);
  }

  .hero-copy h1 {
    max-width: 11ch;
    margin-bottom: 1rem;
    font-size: clamp(3rem, 7vw, 5.8rem);
    line-height: 0.94;
  }

  .hero-copy p {
    max-width: 34rem;
    margin-bottom: 0;
    font-size: 1.08rem;
  }

  .eyebrow {
    display: inline-block;
    margin-bottom: 1.25rem;
    color: var(--accent);
    font-size: 0.78rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.35rem;
    padding: 0.85rem 1.4rem;
    border-radius: 999px;
    font-size: 0.84rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      background 180ms ease;
  }

  .button:hover,
  .button:focus-visible {
    transform: translateY(-1px);
  }

  .button-primary {
    background: linear-gradient(135deg, var(--text), var(--accent));
    color: var(--bg);
    box-shadow: 0 14px 28px rgba(77, 45, 70, 0.16);
  }

  .button-secondary {
    border: 1px solid var(--line);
    color: var(--text);
    background: rgba(255, 255, 255, 0.44);
  }

  .hero-card {
    border-radius: var(--radius-xl);
    padding: 1rem;
  }

  .hero-card-inner {
    height: 100%;
    padding: 2rem;
    border-radius: calc(var(--radius-xl) - 10px);
    background:
      linear-gradient(180deg, rgba(152, 98, 129, 0.12), rgba(77, 45, 70, 0.04)),
      rgba(255, 255, 255, 0.4);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 100%;
  }

  .card-label,
  .panel-index {
    color: var(--accent);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-size: 0.72rem;
  }

  .hero-card h2,
  .section-heading h2,
  .contact-card h2 {
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1;
  }

  .section {
    padding: 1.5rem 0;
  }

  .section-heading {
    margin-bottom: 1.5rem;
  }

  .collection-grid,
  .process-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .panel,
  .process-step {
    padding: 1.6rem;
    border-radius: var(--radius-lg);
  }

  .panel h3,
  .process-step h3 {
    margin: 0.5rem 0 0.75rem;
    font-size: 1.5rem;
  }

  .section-split {
    padding-top: 2.5rem;
  }

  .split-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 1.5rem;
    align-items: start;
  }

  .split-copy {
    padding: 1.8rem 0 0;
  }

  .process-step strong {
    color: var(--accent);
    font-size: 0.9rem;
    letter-spacing: 0.2em;
  }

  .contact-card {
    padding: clamp(2rem, 4vw, 3rem);
    border-radius: var(--radius-xl);
    text-align: center;
  }

  .contact-card p {
    margin: 0 auto 1.75rem;
    max-width: 36rem;
  }

  @media (max-width: 900px) {
    .hero-grid,
    .collection-grid,
    .process-grid,
    .split-grid {
      grid-template-columns: 1fr;
    }

    .hero-copy h1 {
      max-width: 12ch;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding-top: 4rem;
    }

    .hero-copy,
    .hero-card-inner,
    .panel,
    .process-step,
    .contact-card {
      padding: 1.5rem;
    }

    .hero-copy h1,
    .hero-card h2,
    .section-heading h2,
    .contact-card h2 {
      line-height: 1.02;
    }
  }
</style>
