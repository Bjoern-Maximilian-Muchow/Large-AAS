---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
---

<BaseLayout>
  <div id="top">
    <Header />

    <main>
      <section class="hero">
        <div class="container hero-grid">
          <div class="hero-copy">
            <span class="eyebrow">Lattis Seating Solutions</span>
            <h1>Light, breathable comfort.</h1>
            <p>
              Lightweight passenger seat cushions made from a single recyclable
              material for cleaner cabins, lower weight, and a more comfortable
              flight experience.
            </p>

            <div class="hero-actions">
              <a class="button button-primary" href="#collection">Explore Benefits</a>
              <a class="button button-secondary" href="#contact">Talk to Lattis</a>
            </div>
          </div>

          <div class="hero-card">
            <div class="hero-card-inner">
              <span class="card-label">Vision</span>
              <h2>More comfort for passengers. Lower cost for airlines.</h2>
              <p>
                Less seat weight means lower fuel consumption, while breathable
                ergonomic support improves the onboard experience. A practical
                win-win for both customer and airline.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section class="section" id="collection">
        <div class="container">
          <div class="section-heading">
            <span class="eyebrow">Customer Benefits</span>
            <h2>Built around the advantages that matter in aviation.</h2>
          </div>

          <div class="collection-grid">
            <article class="panel">
              <span class="tile-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                  <path d="M6 15c4.5-6.2 9.8-7.7 12-7-1.7 2.6-3.7 5.2-6.2 7.4C9.8 17.2 7.6 18 6 18c-.4-.8-.4-1.9 0-3Z" />
                  <path d="M6 18c2-1.1 4.4-1.8 7-2" />
                </svg>
              </span>
              <span class="panel-index">01</span>
              <h3>Low Weight</h3>
              <p>
                Reduced cushion weight helps lower aircraft mass and supports
                more fuel-efficient operations.
              </p>
            </article>

            <article class="panel">
              <span class="tile-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                  <path d="M7 7h10" />
                  <path d="M9 4h6" />
                  <path d="M8 10l1 8h6l1-8" />
                  <path d="M10 10V7" />
                  <path d="M14 10V7" />
                  <path d="M6 18h12" />
                </svg>
              </span>
              <span class="panel-index">02</span>
              <h3>Easy Cleaning</h3>
              <p>
                A simple material concept supports faster maintenance and a
                cleaner, more durable cabin environment.
              </p>
            </article>

            <article class="panel">
              <span class="tile-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                  <path d="M6 12h7" />
                  <path d="M4 9h10" />
                  <path d="M8 15h8" />
                  <path d="M15 6c1.7 1.1 3 2.9 3 5.2 0 3.1-2.2 5.5-5.3 6.6" />
                  <path d="M15 18c1.5-.6 2.8-1.6 3.8-3" />
                </svg>
              </span>
              <span class="panel-index">03</span>
              <h3>Breathable Comfort</h3>
              <p>
                Breathable cushioning improves seating comfort while variable
                hardness supports a more ergonomic sitting position.
              </p>
            </article>
          </div>
        </div>
      </section>

      <section class="section section-split" id="craft">
        <div class="container split-grid">
          <div>
            <span class="eyebrow">Material Concept</span>
            <h2>One material. Smarter performance. Easier recycling.</h2>
          </div>

          <div class="split-copy">
            <p>
              Lattis focuses on passenger seat cushions produced from a single
              material, making the product easier to recycle at end of life and
              simpler to integrate into sustainable cabin strategies.
            </p>
            <p>
              The material is designed to be fire-resistant, UV-resistant, and
              breathable while still allowing differentiated hardness for
              ergonomic support.
            </p>
          </div>
        </div>
      </section>

      <section class="section" id="process">
        <div class="container">
          <div class="section-heading">
            <span class="eyebrow">Key Features</span>
            <h2>Engineered for cabin requirements and passenger wellbeing.</h2>
          </div>

          <div class="process-grid">
            <article class="process-step">
              <span class="tile-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                  <path d="M12 4c-1.8 2-3.5 4-3.5 6.6 0 2.6 1.8 4.6 4.2 4.6 2.1 0 3.8-1.5 3.8-3.7 0-1.8-1.1-3.4-2.2-4.8-.6-.8-1.3-1.6-2.3-2.7Z" />
                  <path d="M4.5 19.5 19.5 4.5" />
                </svg>
              </span>
              <strong>01</strong>
              <h3>Fire-Resistant</h3>
              <p>Suitable for demanding safety environments with material performance built in.</p>
            </article>

            <article class="process-step">
              <span class="tile-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                  <circle cx="12" cy="12" r="4" />
                  <path d="M12 2v3" />
                  <path d="M12 19v3" />
                  <path d="M4.9 4.9l2.1 2.1" />
                  <path d="M17 17l2.1 2.1" />
                  <path d="M2 12h3" />
                  <path d="M19 12h3" />
                  <path d="M4.9 19.1 7 17" />
                  <path d="M17 7l2.1-2.1" />
                </svg>
              </span>
              <strong>02</strong>
              <h3>UV-Resistant</h3>
              <p>Designed to retain quality and appearance even under repeated light exposure.</p>
            </article>

            <article class="process-step">
              <span class="tile-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                  <path d="M6 18V9" />
                  <path d="M12 18V6" />
                  <path d="M18 18v-4" />
                  <path d="M4 18h16" />
                  <path d="M5 9h2" />
                  <path d="M11 6h2" />
                  <path d="M17 14h2" />
                </svg>
              </span>
              <strong>03</strong>
              <h3>Variable Hardness</h3>
              <p>Targeted support zones help create a more ergonomic and comfortable sitting posture.</p>
            </article>
          </div>
        </div>
      </section>

      <section class="section" id="contact">
        <div class="container contact-card">
          <span class="eyebrow">Partnership</span>
          <h2>Let’s build seating that makes flying more comfortable and more efficient.</h2>
          <p>
            Speak with Lattis about lightweight, breathable and recyclable
            passenger seat cushions for next-generation aircraft interiors.
          </p>
          <a class="button button-primary" href="mailto:studio@lattis.com">studio@lattis.com</a>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>

<style>
  main {
    padding-bottom: 4rem;
  }

  .hero {
    padding: 5.5rem 0 3rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
    gap: 1.5rem;
    align-items: stretch;
  }

  .hero-copy,
  .hero-card,
  .panel,
  .process-step,
  .contact-card {
    position: relative;
    border: 1px solid var(--line);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0.58));
    box-shadow: var(--shadow-soft);
    transition:
      transform 220ms ease,
      box-shadow 220ms ease,
      border-color 220ms ease,
      background 220ms ease;
  }

  .hero-copy:hover,
  .hero-copy:focus-within,
  .hero-card:hover,
  .hero-card:focus-within,
  .panel:hover,
  .panel:focus-within,
  .process-step:hover,
  .process-step:focus-within,
  .contact-card:hover,
  .contact-card:focus-within {
    transform: translateY(-6px);
    border-color: rgba(152, 98, 129, 0.34);
    box-shadow: 0 24px 46px rgba(77, 45, 70, 0.14);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(255, 255, 255, 0.68));
  }

  .hero-copy {
    padding: clamp(2rem, 4vw, 4rem);
    border-radius: var(--radius-xl);
  }

  .hero-copy h1 {
    max-width: 11ch;
    margin-bottom: 1rem;
    font-size: clamp(3rem, 7vw, 5.8rem);
    line-height: 0.94;
  }

  .hero-copy p {
    max-width: 34rem;
    margin-bottom: 0;
    font-size: 1.08rem;
  }

  .eyebrow {
    display: inline-block;
    margin-bottom: 1.25rem;
    color: var(--accent);
    font-size: 0.78rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.35rem;
    padding: 0.85rem 1.4rem;
    border-radius: 999px;
    font-size: 0.84rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      background 180ms ease;
  }

  .button:hover,
  .button:focus-visible {
    transform: translateY(-1px);
  }

  .button-primary {
    background: linear-gradient(135deg, var(--text), var(--accent));
    color: var(--bg);
    box-shadow: 0 14px 28px rgba(77, 45, 70, 0.16);
  }

  .button-secondary {
    border: 1px solid var(--line);
    color: var(--text);
    background: rgba(255, 255, 255, 0.44);
  }

  .hero-card {
    border-radius: var(--radius-xl);
    padding: 1rem;
  }

  .hero-card-inner {
    height: 100%;
    padding: 2rem;
    border-radius: calc(var(--radius-xl) - 10px);
    background:
      linear-gradient(180deg, rgba(152, 98, 129, 0.12), rgba(77, 45, 70, 0.04)),
      rgba(255, 255, 255, 0.4);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 100%;
  }

  .card-label,
  .panel-index {
    color: var(--accent);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-size: 0.72rem;
  }

  .hero-card h2,
  .section-heading h2,
  .contact-card h2 {
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1;
  }

  .section {
    padding: 1.5rem 0;
  }

  .section-heading {
    margin-bottom: 1.5rem;
  }

  .collection-grid,
  .process-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .panel,
  .process-step {
    padding: 1.6rem;
    border-radius: var(--radius-lg);
  }

  .tile-icon {
    display: inline-grid;
    place-items: center;
    width: 3.25rem;
    height: 3.25rem;
    margin-bottom: 1rem;
    border-radius: 50%;
    color: var(--accent);
    background: linear-gradient(180deg, rgba(152, 98, 129, 0.16), rgba(77, 45, 70, 0.04));
    box-shadow: inset 0 0 0 1px rgba(152, 98, 129, 0.14);
  }

  .tile-icon svg {
    width: 1.5rem;
    height: 1.5rem;
    stroke: currentColor;
    stroke-width: 1.7;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .panel h3,
  .process-step h3 {
    margin: 0.5rem 0 0.75rem;
    font-size: 1.5rem;
  }

  .section-split {
    padding-top: 2.5rem;
  }

  .split-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 1.5rem;
    align-items: start;
  }

  .split-copy {
    padding: 1.8rem 0 0;
  }

  .process-step strong {
    color: var(--accent);
    font-size: 0.9rem;
    letter-spacing: 0.2em;
  }

  .contact-card {
    padding: clamp(2rem, 4vw, 3rem);
    border-radius: var(--radius-xl);
    text-align: center;
  }

  .contact-card p {
    margin: 0 auto 1.75rem;
    max-width: 36rem;
  }

  @media (max-width: 900px) {
    .hero-grid,
    .collection-grid,
    .process-grid,
    .split-grid {
      grid-template-columns: 1fr;
    }

    .hero-copy h1 {
      max-width: 12ch;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding-top: 4rem;
    }

    .hero-copy,
    .hero-card-inner,
    .panel,
    .process-step,
    .contact-card {
      padding: 1.5rem;
    }

    .hero-copy h1,
    .hero-card h2,
    .section-heading h2,
    .contact-card h2 {
      line-height: 1.02;
    }
  }
</style>
