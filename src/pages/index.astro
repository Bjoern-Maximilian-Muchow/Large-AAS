---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
---

<BaseLayout>
  <div id="top">
    <Header />

    <main>
      <section class="office-launch">
        <div class="container office-grid">
          <div class="office-copy">
            <span class="eyebrow">Office Seating</span>
            <h1>Lattice comfort, available now.</h1>
            <p>
              Our lattice-structure office chairs are already successfully sold,
              combining ergonomic support, lightweight comfort, and a distinct
              Lattis material language for modern workspaces.
            </p>

            <div class="hero-actions">
              <a class="button button-primary" href="#contact">Buy Now</a>
              <a class="button button-secondary" href="#airline">Airline Preorder Coming Soon</a>
            </div>
          </div>

          <div class="office-placeholder-card">
            <div class="office-placeholder-inner">
              <span class="card-label">Office Chair Image</span>
              <p>Placeholder for a product image of the office chair currently on sale.</p>
            </div>
          </div>
        </div>
      </section>

      <section class="hero" id="airline">
        <div class="container hero-grid">
          <div class="hero-copy">
            <span class="eyebrow">Airline Seating</span>
            <h1>Light, breathable comfort.</h1>
            <p>
              Lightweight passenger seat cushions made from a single recyclable
              material for cleaner cabins, lower weight, and a more comfortable
              flight experience.
            </p>

            <div class="hero-actions">
              <a class="button button-primary" href="#collection">Explore Benefits</a>
              <a class="button button-secondary" href="#contact">Talk to Lattis</a>
            </div>
          </div>

          <figure class="hero-image-card">
            <img
              src={`${import.meta.env.BASE_URL}konzept01.jpeg`}
              alt="Concept rendering of the Lattis seating cushion"
            />
          </figure>

          <div class="hero-placeholder-card">
            <div class="hero-placeholder-inner">
              <span class="card-label">Coming Soon</span>
              <p>Image placeholder for a future product or cockpit visual.</p>
            </div>
          </div>

          <div class="hero-card hero-card-compact">
            <div class="hero-card-inner">
              <span class="card-label">Vision</span>
              <h2>More comfort for passengers. Lower cost for airlines.</h2>
              <p>
                Less seat weight means lower fuel consumption, while breathable
                ergonomic support improves the onboard experience. A practical
                win-win for both customer and airline.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section class="section" id="collection">
        <div class="container">
          <div class="section-heading">
            <span class="eyebrow">Customer Benefits</span>
            <h2>Built around the advantages that matter in aviation.</h2>
          </div>

          <div class="collection-grid">
            <article class="panel">
              <span class="panel-index">01</span>
              <h3>Low Weight</h3>
              <p>
                Reduced cushion weight helps lower aircraft mass and supports
                more fuel-efficient operations.
              </p>
            </article>

            <article class="panel">
              <span class="panel-index">02</span>
              <h3>Easy Cleaning</h3>
              <p>
                A simple material concept supports faster maintenance and a
                cleaner, more durable cabin environment.
              </p>
            </article>

            <article class="panel">
              <span class="panel-index">03</span>
              <h3>Breathable Comfort</h3>
              <p>
                Breathable cushioning improves seating comfort while variable
                hardness supports a more ergonomic sitting position.
              </p>
            </article>
          </div>
        </div>
      </section>

      <section class="section section-split" id="craft">
        <div class="container split-grid">
          <div>
            <span class="eyebrow">Material Concept</span>
            <h2>One material. Smarter performance. Easier recycling.</h2>
          </div>

          <div class="split-copy">
            <p>
              Lattis focuses on passenger seat cushions produced from a single
              material, making the product easier to recycle at end of life and
              simpler to integrate into sustainable cabin strategies.
            </p>
            <p>
              The material is designed to be fire-resistant, UV-resistant, and
              breathable while still allowing differentiated hardness for
              ergonomic support.
            </p>
          </div>
        </div>
      </section>

      <section class="section" id="process">
        <div class="container">
          <div class="section-heading">
            <span class="eyebrow">Key Features</span>
            <h2>Engineered for cabin requirements and passenger wellbeing.</h2>
          </div>

          <div class="process-grid">
            <article class="process-step">
              <strong>01</strong>
              <h3>Fire-Resistant</h3>
              <p>Suitable for demanding safety environments with material performance built in.</p>
            </article>

            <article class="process-step">
              <strong>02</strong>
              <h3>UV-Resistant</h3>
              <p>Designed to retain quality and appearance even under repeated light exposure.</p>
            </article>

            <article class="process-step">
              <strong>03</strong>
              <h3>Variable Hardness</h3>
              <p>Targeted support zones help create a more ergonomic and comfortable sitting posture.</p>
            </article>
          </div>
        </div>
      </section>

      <section class="section" id="contact">
        <div class="container contact-card">
          <span class="eyebrow">Partnership</span>
          <h2>Let’s build seating that makes flying more comfortable and more efficient.</h2>
          <p>
            Speak with Lattis about lightweight, breathable and recyclable
            passenger seat cushions for next-generation aircraft interiors.
          </p>
          <a class="button button-primary" href="mailto:studio@lattis.com">studio@lattis.com</a>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>

<style>
  main {
    padding-bottom: 4rem;
  }

  .office-launch {
    padding: 3rem 0 1.5rem;
  }

  .office-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.95fr);
    gap: 1.5rem;
    align-items: stretch;
  }

  .hero {
    padding: 5.5rem 0 3rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
    grid-template-areas:
      "copy image"
      "placeholder card";
    gap: 1.5rem;
    align-items: stretch;
  }

  .office-copy,
  .office-placeholder-card,
  .hero-copy,
  .hero-image-card,
  .hero-placeholder-card,
  .hero-card,
  .panel,
  .process-step,
  .contact-card {
    position: relative;
    border: 1px solid var(--line);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0.58));
    box-shadow: var(--shadow-soft);
    transition:
      transform 220ms ease,
      box-shadow 220ms ease,
      border-color 220ms ease,
      background 220ms ease;
  }

  .office-copy:hover,
  .office-copy:focus-within,
  .office-placeholder-card:hover,
  .office-placeholder-card:focus-within,
  .hero-copy:hover,
  .hero-copy:focus-within,
  .hero-card:hover,
  .hero-card:focus-within,
  .panel:hover,
  .panel:focus-within,
  .process-step:hover,
  .process-step:focus-within,
  .contact-card:hover,
  .contact-card:focus-within {
    transform: translateY(-6px);
    border-color: rgba(152, 98, 129, 0.34);
    box-shadow: 0 24px 46px rgba(77, 45, 70, 0.14);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(255, 255, 255, 0.68));
  }

  .hero-copy {
    grid-area: copy;
    padding: clamp(2rem, 4vw, 4rem);
    border-radius: var(--radius-xl);
  }

  .office-copy {
    padding: clamp(2rem, 4vw, 3.5rem);
    border-radius: var(--radius-xl);
  }

  .office-copy h1 {
    max-width: 10ch;
    margin-bottom: 1rem;
    font-size: clamp(3rem, 6vw, 5.2rem);
    line-height: 0.94;
  }

  .office-copy p {
    max-width: 34rem;
    margin-bottom: 0;
    font-size: 1.08rem;
  }

  .office-placeholder-card {
    border-radius: var(--radius-xl);
    padding: 1rem;
  }

  .office-placeholder-inner {
    height: 100%;
    min-height: 420px;
    border: 1px dashed rgba(152, 98, 129, 0.32);
    border-radius: calc(var(--radius-xl) - 10px);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.5), rgba(246, 244, 244, 0.74)),
      repeating-linear-gradient(
        45deg,
        rgba(152, 98, 129, 0.04),
        rgba(152, 98, 129, 0.04) 18px,
        rgba(255, 255, 255, 0.18) 18px,
        rgba(255, 255, 255, 0.18) 36px
      );
    display: grid;
    place-items: center;
    text-align: center;
    padding: 2rem;
  }

  .office-placeholder-inner p {
    max-width: 20rem;
    margin: 0;
    font-size: 1rem;
  }

  .hero-image-card {
    grid-area: image;
    margin: 0;
    overflow: hidden;
    min-height: 100%;
    border-radius: var(--radius-xl);
  }

  .hero-image-card img {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 100%;
    object-fit: cover;
  }

  .hero-placeholder-card {
    grid-area: placeholder;
    border-radius: var(--radius-xl);
    padding: 1rem;
  }

  .hero-placeholder-inner {
    height: 100%;
    min-height: 320px;
    border: 1px dashed rgba(152, 98, 129, 0.32);
    border-radius: calc(var(--radius-xl) - 10px);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.5), rgba(246, 244, 244, 0.74)),
      repeating-linear-gradient(
        -45deg,
        rgba(152, 98, 129, 0.04),
        rgba(152, 98, 129, 0.04) 16px,
        rgba(255, 255, 255, 0.16) 16px,
        rgba(255, 255, 255, 0.16) 32px
      );
    display: grid;
    place-items: center;
    text-align: center;
    padding: 2rem;
  }

  .hero-placeholder-inner p {
    max-width: 20rem;
    margin: 0;
    font-size: 1rem;
  }

  .hero-copy h1 {
    max-width: 11ch;
    margin-bottom: 1rem;
    font-size: clamp(3rem, 7vw, 5.8rem);
    line-height: 0.94;
  }

  .hero-copy p {
    max-width: 34rem;
    margin-bottom: 0;
    font-size: 1.08rem;
  }

  .eyebrow {
    display: inline-block;
    margin-bottom: 1.25rem;
    color: var(--accent);
    font-size: 0.78rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.35rem;
    padding: 0.85rem 1.4rem;
    border-radius: 999px;
    font-size: 0.84rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      background 180ms ease;
  }

  .button:hover,
  .button:focus-visible {
    transform: translateY(-1px);
  }

  .button-primary {
    background: linear-gradient(135deg, var(--text), var(--accent));
    color: var(--bg);
    box-shadow: 0 14px 28px rgba(77, 45, 70, 0.16);
  }

  .button-secondary {
    border: 1px solid var(--line);
    color: var(--text);
    background: rgba(255, 255, 255, 0.44);
  }

  .hero-card {
    grid-area: card;
    border-radius: var(--radius-xl);
    padding: 1rem;
  }

  .hero-card-compact .hero-card-inner {
    min-height: 320px;
  }

  .hero-card-inner {
    height: 100%;
    padding: 2rem;
    border-radius: calc(var(--radius-xl) - 10px);
    background:
      linear-gradient(180deg, rgba(152, 98, 129, 0.12), rgba(77, 45, 70, 0.04)),
      rgba(255, 255, 255, 0.4);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 100%;
  }

  .card-label,
  .panel-index {
    color: var(--accent);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-size: 0.72rem;
  }

  .hero-card h2,
  .section-heading h2,
  .contact-card h2 {
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1;
  }

  .hero-card-compact h2 {
    font-size: clamp(1.8rem, 3vw, 2.4rem);
  }

  .section {
    padding: 1.5rem 0;
  }

  .section-heading {
    margin-bottom: 1.5rem;
  }

  .collection-grid,
  .process-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .panel,
  .process-step {
    padding: 1.6rem;
    border-radius: var(--radius-lg);
  }

  .panel h3,
  .process-step h3 {
    margin: 0.5rem 0 0.75rem;
    font-size: 1.5rem;
  }

  .section-split {
    padding-top: 2.5rem;
  }

  .split-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 1.5rem;
    align-items: start;
  }

  .split-copy {
    padding: 1.8rem 0 0;
  }

  .process-step strong {
    color: var(--accent);
    font-size: 0.9rem;
    letter-spacing: 0.2em;
  }

  .contact-card {
    padding: clamp(2rem, 4vw, 3rem);
    border-radius: var(--radius-xl);
    text-align: center;
  }

  .contact-card p {
    margin: 0 auto 1.75rem;
    max-width: 36rem;
  }

  @media (max-width: 900px) {
    .office-grid,
    .hero-grid,
    .collection-grid,
    .process-grid,
    .split-grid {
      grid-template-columns: 1fr;
    }

    .hero-grid {
      grid-template-areas:
        "copy"
        "image"
        "placeholder"
        "card";
    }

    .hero-copy h1 {
      max-width: 12ch;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding-top: 4rem;
    }

    .office-copy,
    .office-placeholder-inner,
    .hero-copy,
    .hero-card-inner,
    .hero-placeholder-inner,
    .panel,
    .process-step,
    .contact-card {
      padding: 1.5rem;
    }

    .hero-copy h1,
    .hero-card h2,
    .section-heading h2,
    .contact-card h2 {
      line-height: 1.02;
    }
  }
</style>
